
### [api]
# https://docs.github.com/en/rest/models

@set-prompt = What type of problems was your model designed to solve?

@list-role = system
@list*-role = user
@list-role = assistant
@list-role = tool

@list*-stream = false
@list-stream = true

@set-model = openai/gpt-4.1-nano

@set-content = {{prompt}}

@list*-embedding_model = text-embedding-3-large
@list-embedding_model = text-embedding-3-small
@list-embedding_model = text-embedding-ada-002

@list*-encoding = float
@list-encoding = base64
